# Queue / Redis
REDIS_HOST=redis-box
REDIS_PORT=6379
REDIS_QUEUE_NAME=crawl-queue
REDIS_PASSWORD=

# Crawl timing
DWELL_TIME=10
TIMEOUT=60

# Logging
LOG_LEVEL=INFO

# Instruments: 0 = off, 1 = on
CALLSTACK_INSTRUMENT=0
JS_INSTRUMENT=0

# Google Cloud Storage
# Leave empty to disable GCS usage
GCS_BUCKET=

# To enable GCS, set to your service account JSON path on Windows, e.g.
# GOOGLE_APPLICATION_CREDENTIALS=C:\Users\timon\path\to\service-account.json
GOOGLE_APPLICATION_CREDENTIALS=

# Alternative path var some code expects
GCS_CREDENTIALS_PATH=

# Postgres
PG_HOST=
PG_USER=
PG_PASS=
PG_DB=
PG_PORT=
POSTGRES_SCHEMA_FILE="./db/init/postgre_schema.sql"